    "### doing dot product in numpy "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2753c793",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "#feature vector\n",
    "x = np.array([2,3,4])\n",
    "\n",
    "#weight vector\n",
    "w = np.array([50000,30000,-10000])\n",
    "\n",
    "#bias\n",
    "b = 20000\n",
    "\n",
    "#prediction using dot product \n",
    "y = np.dot(w,x) + b\n",
    "\n",
    "print(\"Predicted Price:\", y )\n"
   ]
  }
